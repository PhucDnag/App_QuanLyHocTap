<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_ai_bot.xml — Màn hình AI Chatbot
    Layout: ConstraintLayout với RecyclerView + Suggestion Chips + Input Bar
    Design: Clean, minimal, mobile-first
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- ══════════════════════════════════════════════════ -->
    <!--  HEADER BAR                                        -->
    <!-- ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="#1565C0"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back button -->
        <ImageView
            android:id="@+id/btnAiBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="8dp"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại" />

        <!-- Bot avatar -->
        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginStart="4dp"
            app:cardBackgroundColor="#1976D2">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="AI"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />
        </androidx.cardview.widget.CardView>

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Trợ Giảng"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Luôn sẵn sàng hỗ trợ bạn"
                android:textColor="#B3E5FC"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Reset button -->
        <ImageView
            android:id="@+id/btnAiReset"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:padding="8dp"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Xóa hết tin nhắn" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════ -->
    <!--  CHAT RECYCLERVIEW                                 -->
    <!-- ══════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvAiChat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/layoutSuggestions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════ -->
    <!--  QUICK SUGGESTION CHIPS                            -->
    <!-- ══════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/layoutSuggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#F0F2F5"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSuggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:singleLine="true"
            app:chipSpacingHorizontal="8dp" />
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════ -->
    <!--  INPUT BAR                                         -->
    <!-- ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutInputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Input field -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F2F5">

            <EditText
                android:id="@+id/edtAiInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:background="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:hint="Hỏi bất cứ điều gì về bài học..."
                android:textSize="15sp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4" />
        </androidx.cardview.widget.CardView>

        <!-- Stop button (hiện khi đang stream) -->
        <ImageButton
            android:id="@+id/btnAiStop"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="#E53935"
            android:padding="10dp"
            android:scaleType="fitCenter"
            app:tint="#FFFFFF"
            android:visibility="gone"
            android:contentDescription="Dừng" />

        <!-- Send button -->
        <ImageButton
            android:id="@+id/btnAiSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="#1976D2"
            android:padding="10dp"
            android:scaleType="fitCenter"
            app:tint="#FFFFFF"
            android:contentDescription="Gửi" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
