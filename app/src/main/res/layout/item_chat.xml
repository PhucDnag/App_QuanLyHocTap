<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/layoutLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:background="@drawable/bg_chat_left"
        android:padding="10dp"
        android:layout_marginEnd="50dp">

        <TextView
            android:id="@+id/tvSenderName"
            android:text="Nguyễn Văn A"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#F57F17"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvContentLeft"
            android:text="Nội dung tin nhắn..."
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTimeLeft"
            android:text="10:00"
            android:textSize="10sp"
            android:textColor="#757575"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="end"
        android:background="@drawable/bg_chat_right"
        android:padding="10dp"
        android:layout_marginStart="50dp">

        <TextView
            android:id="@+id/tvContentRight"
            android:text="Tin nhắn của tôi"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTimeRight"
            android:text="10:00"
            android:textSize="10sp"
            android:textColor="#E0E0E0"
            android:layout_gravity="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>