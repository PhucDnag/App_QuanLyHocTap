<?xml version="1.0" encoding="utf-8"?>
<!--
    item_ai_bot_message.xml — Bubble tin nhắn của AI Bot
    Design: Bo tròn trái, màu trắng với border xanh nhạt
    Hỗ trợ hiển thị cursor ▌ khi đang streaming
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="60dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Bot Avatar (icon nhỏ bên trái bubble) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/ivBotAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1976D2">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="AI"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="10sp" />
    </androidx.cardview.widget.CardView>

    <!-- Message Bubble -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBotContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textSize="15sp"
                android:textColor="#111827"
                android:lineSpacingMultiplier="1.4"
                android:text="..."
                android:maxWidth="260dp" />

            <!-- Nút mở lại Flashcard (ẩn mặc định) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenFlashcard"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="6dp"
                android:text="🃏 Mở lại Flashcard"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
