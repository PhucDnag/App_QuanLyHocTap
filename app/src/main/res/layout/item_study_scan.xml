<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:background="#FFFFFF"
    android:elevation="2dp"
    android:padding="14dp">

    <!-- Tên chương -->
    <TextView
        android:id="@+id/tvScanChapterName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#111827"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/pbScanProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:max="100"
        android:progressBackgroundTint="#E0E0E0"
        android:progressTint="#1976D2" />

    <!-- Chi tiết: Quiz + Bài tập -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvScanQuizStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#555" />

        <TextView
            android:id="@+id/tvScanAssStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#555"
            android:gravity="end" />

    </LinearLayout>

    <!-- Chi tiết: PDF + Video (Mới nâng cấp) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tvScanPdfStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#555" />

        <TextView
            android:id="@+id/tvScanVideoStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#555"
            android:gravity="end" />

    </LinearLayout>

    <!-- Badge trạng thái -->
    <TextView
        android:id="@+id/tvScanBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

</LinearLayout>
