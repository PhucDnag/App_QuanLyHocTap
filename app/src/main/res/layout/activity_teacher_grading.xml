<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1976D2"
        android:paddingHorizontal="16dp">
        <ImageView android:id="@+id/btnBack" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_back_arrow" app:tint="@color/white" android:layout_centerVertical="true"/>
        <TextView android:id="@+id/tvHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chấm bài" android:textColor="#FFF" android:textSize="18sp" android:textStyle="bold" android:layout_centerInParent="true"/>
    </RelativeLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <TextView android:id="@+id/tvQuestionTitle" android:text="Chương 2: CPU" android:textStyle="bold" android:textSize="18sp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/white">
                <TextView android:id="@+id/tvQuestionContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="Câu hỏi bài tập..." android:textSize="16sp"/>
            </androidx.cardview.widget.CardView>

            <TextView android:text="Bài làm của sinh viên:" android:layout_marginTop="20dp" android:layout_marginBottom="8dp" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/white">
                <TextView android:id="@+id/tvStudentAnswer" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="Sinh viên chưa nộp bài..." android:textColor="#000" android:background="#FFF3E0"/>
            </androidx.cardview.widget.CardView>

            <TextView android:text="Điểm số:" android:layout_marginTop="20dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/edtScore" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nhập điểm (0-10)" android:inputType="numberDecimal" android:background="@android:drawable/edit_text"/>

            <TextView android:text="Nhận xét:" android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/edtFeedback" android:layout_width="match_parent" android:layout_height="100dp" android:gravity="top" android:hint="Nhập lời phê..." android:background="@android:drawable/edit_text"/>

            <Button android:id="@+id/btnSubmitGrade" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Submit (Lưu điểm)" android:layout_marginTop="24dp" android:backgroundTint="#1976D2"/>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavTeacher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu" />
</LinearLayout>