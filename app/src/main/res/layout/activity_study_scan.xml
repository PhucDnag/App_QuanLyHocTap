<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerScan"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="#1565C0"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btnScanBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="8dp"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Quét Tiến Độ Học"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScanSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang quét..."
                android:textColor="#B3E5FC"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Summary card -->
    <LinearLayout
        android:id="@+id/layoutSummaryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="12dp"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:elevation="3dp">

        <!-- Hoàn thành -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/tvCountDone"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="28sp" android:textStyle="bold"
                android:textColor="#2E7D32"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅ Hoàn thành" android:textSize="11sp" android:textColor="#666"/>
        </LinearLayout>

        <!-- Đang học -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/tvCountPartial"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="28sp" android:textStyle="bold"
                android:textColor="#F57C00"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔄 Đang học" android:textSize="11sp" android:textColor="#666"/>
        </LinearLayout>

        <!-- Chưa học -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:gravity="center">
            <TextView android:id="@+id/tvCountTodo"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="28sp" android:textStyle="bold"
                android:textColor="#C62828"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="❌ Chưa học" android:textSize="11sp" android:textColor="#666"/>
        </LinearLayout>

    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvStudyScan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
